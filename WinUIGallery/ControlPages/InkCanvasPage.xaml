<Page x:Class="WinUIGallery.ControlPages.InkCanvasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUIGallery"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="16">
        <!-- ============================================================= -->
        <!-- EXAMPLE 1: Default inking                                      -->
        <!-- A bare InkCanvas produces wet ink for mouse, pen, and touch    -->
        <!-- with no app code. All ink configuration flows through its      -->
        <!-- read-only InkPresenter, mirroring the classic InkCanvas.       -->
        <!-- ============================================================= -->
        <local:ControlExample x:Name="Example1" HeaderText="A default InkCanvas inks out of the box — just draw on it.">
            <Border BorderBrush="{ThemeResource SystemControlForegroundChromeHighBrush}" BorderThickness="1"
                    Width="600" Height="400" Background="White">
                <InkCanvas x:Name="inkCanvas1" />
            </Border>
            <local:ControlExample.Xaml>
                <x:String xml:space="preserve">
&lt;InkCanvas /&gt;
                </x:String>
            </local:ControlExample.Xaml>
        </local:ControlExample>

        <!-- ============================================================= -->
        <!-- EXAMPLE 2: InkToolBar paired with InkCanvas                    -->
        <!-- The toolbar drives the canvas's InkPresenter (pen, eraser,     -->
        <!-- color and width) via TargetInkCanvas.                          -->
        <!-- ============================================================= -->
        <local:ControlExample x:Name="Example2" HeaderText="Pair an InkToolBar with an InkCanvas to switch pen, eraser, color, and width.">
            <StackPanel Spacing="8">
                <InkToolBar x:Name="inkToolBar2" TargetInkCanvas="{x:Bind inkCanvas2}" />
                <Border BorderBrush="{ThemeResource SystemControlForegroundChromeHighBrush}" BorderThickness="1"
                        Width="600" Height="300" Background="White">
                    <InkCanvas x:Name="inkCanvas2" />
                </Border>
            </StackPanel>
            <local:ControlExample.Xaml>
                <x:String xml:space="preserve">
&lt;InkToolBar TargetInkCanvas="{x:Bind inkCanvas}" /&gt;
&lt;InkCanvas x:Name="inkCanvas" /&gt;
                </x:String>
            </local:ControlExample.Xaml>
        </local:ControlExample>

        <!-- ============================================================= -->
        <!-- EXAMPLE 3: Configure the InkPresenter from code                -->
        <!-- Sets InputDeviceTypes, the default drawing attributes, and     -->
        <!-- IsInputEnabled directly on InkCanvas.InkPresenter, exactly     -->
        <!-- like the classic Windows.UI.Xaml.Controls.InkCanvas.           -->
        <!-- ============================================================= -->
        <local:ControlExample x:Name="Example3" HeaderText="Configure the InkPresenter from code, exactly like the classic InkCanvas.">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="redPenButton" Content="Red thick pen" Click="OnRedPenClick" />
                    <Button x:Name="bluePenButton" Content="Blue thin pen" Click="OnBluePenClick" />
                    <ToggleSwitch x:Name="touchToggle" Header="Touch inking" IsOn="True" Toggled="OnTouchToggled" />
                    <ToggleSwitch x:Name="enabledToggle" Header="Inking enabled" IsOn="True" Toggled="OnEnabledToggled" />
                </StackPanel>
                <Border BorderBrush="{ThemeResource SystemControlForegroundChromeHighBrush}" BorderThickness="1"
                        Width="600" Height="300" Background="White">
                    <InkCanvas x:Name="inkCanvas3" />
                </Border>
            </StackPanel>
            <local:ControlExample.CSharp>
                <x:String xml:space="preserve">
// Configure the presenter directly, just like the classic InkCanvas.
inkCanvas.InkPresenter.InputDeviceTypes =
    CoreInputDeviceTypes.Mouse | CoreInputDeviceTypes.Pen | CoreInputDeviceTypes.Touch;

var attributes = inkCanvas.InkPresenter.CopyDefaultDrawingAttributes();
attributes.Color = Microsoft.UI.Colors.Red;
attributes.Size = new Windows.Foundation.Size(6, 6);
inkCanvas.InkPresenter.UpdateDefaultDrawingAttributes(attributes);
                </x:String>
            </local:ControlExample.CSharp>
        </local:ControlExample>

        <!-- ============================================================= -->
        <!-- EXAMPLE 4: Stroke container and stroke events                 -->
        <!-- Uses InkPresenter.StrokeContainer to enumerate, clear, save,  -->
        <!-- and reload strokes, and listens to StrokesCollected /         -->
        <!-- StrokesErased, exactly like the classic InkCanvas.            -->
        <!-- ============================================================= -->
        <local:ControlExample x:Name="Example4" HeaderText="Manage strokes and listen to stroke events through InkPresenter.StrokeContainer.">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="countButton" Content="Count strokes" Click="OnCountStrokesClick" />
                    <Button x:Name="clearButton" Content="Clear" Click="OnClearStrokesClick" />
                    <Button x:Name="saveReloadButton" Content="Save &amp; reload (in-memory)" Click="OnSaveReloadClick" />
                </StackPanel>
                <TextBlock x:Name="statusText4" Text="Draw on the canvas below." TextWrapping="Wrap" />
                <Border BorderBrush="{ThemeResource SystemControlForegroundChromeHighBrush}" BorderThickness="1"
                        Width="600" Height="300" Background="White">
                    <InkCanvas x:Name="inkCanvas4" />
                </Border>
            </StackPanel>
            <local:ControlExample.CSharp>
                <x:String xml:space="preserve">
// Listen to stroke events.
inkCanvas.InkPresenter.StrokesCollected += (s, e) =&gt;
    statusText.Text = $"Collected {e.Strokes.Count} stroke(s).";
inkCanvas.InkPresenter.StrokesErased += (s, e) =&gt;
    statusText.Text = $"Erased {e.Strokes.Count} stroke(s).";

// Enumerate and clear.
var strokes = inkCanvas.InkPresenter.StrokeContainer.GetStrokes();
inkCanvas.InkPresenter.StrokeContainer.Clear();

// Save and reload through a stream.
var stream = new InMemoryRandomAccessStream();
await inkCanvas.InkPresenter.StrokeContainer.SaveAsync(stream.GetOutputStreamAt(0));
inkCanvas.InkPresenter.StrokeContainer.Clear();
await inkCanvas.InkPresenter.StrokeContainer.LoadAsync(stream.GetInputStreamAt(0));
                </x:String>
            </local:ControlExample.CSharp>
        </local:ControlExample>
    </StackPanel>
</Page>