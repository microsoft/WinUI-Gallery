<Page
    x:Class="WinUIGallery.ControlPages.CustomXamlConditionalsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WinUIGallery.Controls"
    xmlns:cond="using:WinUIGallery.ControlPages"
    xmlns:newExp="http://schemas.microsoft.com/winfx/2006/xaml/presentation?cond:FeatureFlagCondition(NewExperience)"
    xmlns:legacy="http://schemas.microsoft.com/winfx/2006/xaml/presentation?cond:FeatureFlagCondition(LegacyMode)"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Spacing="12">

        <InfoBar
            Title="Parse-time evaluation"
            IsClosable="False"
            IsOpen="True"
            Message="Custom XAML conditions are evaluated by the XAML parser when the page is loaded, and the result for each (condition, argument) pair is cached for the lifetime of the process. The Options below set the flags so the next page that gets parsed sees the new values - re-navigate to this sample to see the effect."
            Severity="Informational" />

        <controls:ControlExample HeaderText="Conditional elements" XamlSource="CustomXamlConditionals/CustomXamlConditionalsSample1_xaml.txt" CSharpSource="CustomXamlConditionals/CustomXamlConditionalsSample1_cs.txt">
            <StackPanel Spacing="8">
                <newExp:InfoBar
                    Title="New experience"
                    IsClosable="False"
                    IsOpen="True"
                    Message="This InfoBar is included because the 'NewExperience' flag was true when the page was parsed."
                    Severity="Success" />
                <legacy:InfoBar
                    Title="Legacy mode"
                    IsClosable="False"
                    IsOpen="True"
                    Message="This InfoBar is included because the 'LegacyMode' flag was true when the page was parsed."
                    Severity="Warning" />
            </StackPanel>
            <controls:ControlExample.Options>
                <StackPanel Spacing="4">
                    <TextBlock Text="Active flag" />
                    <ComboBox
                        x:Name="ElementsModeComboBox"
                        AutomationProperties.Name="Active flag"
                        SelectionChanged="OnModeSelectionChanged">
                        <x:String>NewExperience</x:String>
                        <x:String>LegacyMode</x:String>
                    </ComboBox>
                </StackPanel>
            </controls:ControlExample.Options>
        </controls:ControlExample>

        <controls:ControlExample HeaderText="Conditional attributes" XamlSource="CustomXamlConditionals/CustomXamlConditionalsSample2_xaml.txt" CSharpSource="CustomXamlConditionals/CustomXamlConditionalsSample2_cs.txt">
            <Button
                newExp:Background="{ThemeResource SystemFillColorSuccessBrush}"
                legacy:Background="{ThemeResource SystemFillColorCautionBrush}"
                Content="Background depends on the active flag"
                Foreground="White" />
            <controls:ControlExample.Options>
                <StackPanel Spacing="4">
                    <TextBlock Text="Active flag" />
                    <ComboBox
                        x:Name="AttributesModeComboBox"
                        AutomationProperties.Name="Active flag"
                        SelectionChanged="OnModeSelectionChanged">
                        <x:String>NewExperience</x:String>
                        <x:String>LegacyMode</x:String>
                    </ComboBox>
                </StackPanel>
            </controls:ControlExample.Options>
        </controls:ControlExample>

        <controls:ControlExample HeaderText="Conditional Setters in a Style" XamlSource="CustomXamlConditionals/CustomXamlConditionalsSample3_xaml.txt" CSharpSource="CustomXamlConditionals/CustomXamlConditionalsSample3_cs.txt">
            <StackPanel Spacing="8">
                <StackPanel.Resources>
                    <Style x:Key="ConditionalButtonStyle" TargetType="Button">
                        <newExp:Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                        <legacy:Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="20,10" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </StackPanel.Resources>
                <Button Content="Styled with conditional Setters" Style="{StaticResource ConditionalButtonStyle}" />
            </StackPanel>
            <controls:ControlExample.Options>
                <StackPanel Spacing="4">
                    <TextBlock Text="Active flag" />
                    <ComboBox
                        x:Name="SettersModeComboBox"
                        AutomationProperties.Name="Active flag"
                        SelectionChanged="OnModeSelectionChanged">
                        <x:String>NewExperience</x:String>
                        <x:String>LegacyMode</x:String>
                    </ComboBox>
                </StackPanel>
            </controls:ControlExample.Options>
        </controls:ControlExample>

        <controls:ControlExample HeaderText="The IXamlCondition implementation" CSharpSource="CustomXamlConditionals/CustomXamlConditionalsSample4_cs.txt" />

    </StackPanel>
</Page>

